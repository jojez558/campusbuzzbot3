# ═══════════════════════════════════════════════════════════
#   CampusBuzz Kenya — Environment Variables
#   Copy this file to .env and fill in your values.
#   NEVER commit .env to git!
# ═══════════════════════════════════════════════════════════

# ── Bot Token (from @BotFather) ───────────────────────────
BOT_TOKEN=7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Admin Settings ────────────────────────────────────────
ADMIN_ID=123456789
ADMIN_USERNAME=DevMwaura
BOT_USERNAME=CampusBuzzKEBot

# ── Force Join Channel ────────────────────────────────────
REQUIRED_CHANNEL=@CampusBuzz
REQUIRED_CHANNEL_LINK=https://t.me/CampusBuzz
REQUIRED_CHANNEL_NAME=CampusBuzz

# ── PostgreSQL Database ───────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://campusbuzz:your_password@localhost:5432/campusbuzz

# ── Redis (FSM + Rate Limiting) ───────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Webhook (leave blank for long-polling in dev) ─────────
# WEBHOOK_URL=https://your-domain.com
# PORT=8080

# ── Gamification XP ───────────────────────────────────────
XP_JOIN_DAILY=10
XP_SUBMIT_GROUP=50
XP_REFERRAL=100
XP_REPORT_VALID=25

# ── Feature Flags ─────────────────────────────────────────
ENABLE_AI_SUGGESTIONS=false
ENABLE_MONETIZATION=false
MAINTENANCE_MODE=false

# ── Pagination ────────────────────────────────────────────
ITEMS_PER_PAGE=8
GROUPS_PER_PAGE=5
